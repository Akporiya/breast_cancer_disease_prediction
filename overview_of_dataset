    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# Load dataset\n",
    "df = pd.read_csv(\"/kaggle/input/datasets/akporiya/breast-cancer/breast-cancer.csv\")\n",
    "\n",
    "print(\"=\"*50)\n",
    "print(\"Dataset Shape\")\n",
    "print(df.shape)\n",
    "\n",
    "print(\"=\"*50)\n",
    "print(\"Columns\")\n",
    "print(df.columns)\n",
    "\n",
    "print(\"=\"*50)\n",
    "print(\"Information\")\n",
    "df.info()\n",
    "\n",
    "print(\"=\"*50)\n",
    "print(\"Missing Values\")\n",
    "print(df.isnull().sum())\n",
    "\n",
    "print(\"=\"*50)\n",
    "print(\"Duplicate Rows\")\n",
    "print(df.duplicated().sum())\n",
    "\n",
    "print(\"=\"*50)\n",
    "print(\"Statistics\")\n",
    "print(df.describe())\n",
    "\n",
    "# Target Distribution\n",
    "df[\"diagnosis\"].value_counts().plot(kind=\"bar\")\n",
    "plt.title(\"Diagnosis Distribution\")\n",
    "plt.show()\n",
    "\n",
    "# Correlation Heatmap\n",
    "plt.figure(figsize=(15,10))\n",
    "plt.imshow(df.corr(numeric_only=True), cmap=\"coolwarm\")\n",
    "plt.colorbar()\n",
    "plt.title(\"Correlation Matrix\")\n",
    "plt.show()"
